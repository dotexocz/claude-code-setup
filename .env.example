# Šablona proměnných prostředí pro tento projekt.
# Zkopíruj do `.env` a vyplň skutečné hodnoty.
# Soubor `.env` se NIKDY necommituje do gitu (viz .gitignore).

# ----- GitHub MCP server -----
# Personal Access Token pro GitHub MCP server.
# Vytvoř na: https://github.com/settings/personal-access-tokens
# Doporučená oprávnění (fine-grained PAT, scoped na konkrétní repa):
#   - Contents: Read (čtení souborů, branchí)
#   - Issues: Read and write
#   - Pull requests: Read and write
#   - Metadata: Read (povinné)
GITHUB_PERSONAL_ACCESS_TOKEN=

# ----- Volitelné: OpenTelemetry / observability -----
# Pokud chceš zapnout sběr metrik v Claude Code, odkomentuj:
# CLAUDE_CODE_ENABLE_TELEMETRY=1
# OTEL_METRICS_EXPORTER=console
# OTEL_LOGS_EXPORTER=console
# OTEL_METRIC_EXPORT_INTERVAL=60000
